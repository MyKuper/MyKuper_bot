# Токены и пароли. Чтобы никто не украл бота
.env
.env.local
.env.production

# Python-мусор. Создаётся сам, не нужен
__pycache__/
*.py[cod]
*.pyc
*.so

# Виртуалка с библиотеками. Весит много, лучше скачать заново
venv/
env/
.venv/

# Настройки IDE (PyCharm/VS Code). У каждого свои
.idea/
.vscode/
*.swp
*.swo

# Логи и папка с отчётами. Генерируются при работе
*.log
reports/
